<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Customisation Request — Modelling Studio HUB</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,700;1,300&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0a0a0c;--bg2:#0f0f12;--bg3:#141418;--bg4:#1a1a20;
  --line:rgba(255,255,255,0.07);--line2:rgba(255,255,255,0.12);
  --text:#e8e8ea;--text2:#8a8a95;--text3:#4a4a55;
  --cyan:#00d4ff;--cyan-dim:rgba(0,212,255,0.07);
  --mono:'JetBrains Mono',monospace;--display:'Syne',sans-serif;
}
html{scroll-behavior:smooth}
body{font-family:var(--mono);background:var(--bg);color:var(--text);font-size:13px;line-height:1.6}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--text3)}::-webkit-scrollbar-thumb:hover{background:var(--cyan)}
nav{position:fixed;top:0;width:100%;background:rgba(10,10,12,0.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--line);z-index:100}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 32px;height:52px;display:flex;align-items:center;justify-content:space-between}
.logo{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--text);text-decoration:none;display:flex;align-items:center;gap:8px}
.logo .br{color:var(--cyan)}
.logo-v{font-size:9px;color:var(--text3);background:var(--bg4);padding:2px 7px;border:1px solid var(--line2);letter-spacing:.06em}
.nav-links{display:flex;list-style:none}
.nav-links a{color:var(--text2);text-decoration:none;font-size:11px;letter-spacing:.06em;padding:8px 20px;border-left:1px solid var(--line);transition:color .15s,background .15s}
.nav-links a:hover{color:var(--cyan);background:var(--cyan-dim)}

.page-header{margin-top:52px;padding:72px 72px 56px;border-bottom:1px solid var(--line);position:relative;overflow:hidden}
.page-header::before{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:48px 48px;pointer-events:none}
.page-header>*{position:relative;z-index:1}
.section-tag{font-size:10px;letter-spacing:.14em;color:var(--cyan);margin-bottom:14px;display:flex;align-items:center;gap:8px;opacity:.8}
.section-tag::before{content:'//';opacity:.6}
.page-title{font-family:var(--display);font-size:clamp(32px,4vw,52px);font-weight:800;line-height:1.06;color:var(--text)}
.page-title .hl{color:var(--cyan)}
.page-sub{font-size:12px;color:var(--text2);margin-top:14px;max-width:520px;line-height:1.85}

.form-layout{display:grid;grid-template-columns:320px 1fr}
.form-sidebar{padding:48px 44px 48px 72px;border-right:1px solid var(--line)}
.sidebar-block{margin-bottom:36px}
.sidebar-block+.sidebar-block{padding-top:32px;border-top:1px solid var(--line)}
.sb-title{font-size:10px;letter-spacing:.14em;color:var(--cyan);margin-bottom:12px;display:flex;align-items:center;gap:6px;opacity:.8}
.sb-title::before{content:'//';opacity:.6}
.sb-text{font-size:11px;color:var(--text2);line-height:1.85}
.sb-row{padding:13px 0;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;gap:12px}
.sb-row:first-child{border-top:1px solid var(--line)}
.sb-label{font-size:10px;letter-spacing:.1em;color:var(--text3)}
.sb-val{font-size:11px;color:var(--text)}
.sb-val a{color:var(--cyan);text-decoration:none;opacity:.8;transition:opacity .15s}
.sb-val a:hover{opacity:1}

.form-main{padding:48px 72px 48px 52px}
.form-main h3{font-family:var(--display);font-size:20px;font-weight:800;margin-bottom:4px}
.form-main .sub{font-size:11px;color:var(--text3);margin-bottom:28px}
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:10px;letter-spacing:.1em;color:var(--text3);margin-bottom:6px}
.form-group input,.form-group select,.form-group textarea{width:100%;background:var(--bg3);border:1px solid var(--line2);padding:11px 14px;font-family:var(--mono);font-size:12px;color:var(--text);outline:none;transition:border-color .15s;border-radius:0;-webkit-appearance:none}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:var(--cyan)}
.form-group textarea{resize:vertical;min-height:130px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.file-note{font-size:10px;color:var(--text3);margin-top:6px}
option{background:var(--bg3)}
.btn-submit{background:var(--cyan);color:var(--bg);padding:13px;font-family:var(--mono);font-size:11px;letter-spacing:.1em;font-weight:700;border:none;cursor:pointer;transition:opacity .15s;width:100%;margin-top:8px;display:block;text-align:center}
.btn-submit:hover{opacity:.85}

footer{background:var(--bg2);padding:28px 72px;border-top:1px solid var(--line);display:flex;justify-content:space-between;align-items:center}
.foot-logo{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:5px}
.foot-logo .br{color:var(--cyan)}
.foot-copy{font-size:10px;color:var(--text3)}

@media(max-width:900px){
  .form-layout{grid-template-columns:1fr}
  .form-sidebar{border-right:none;padding:40px 28px}
  .form-main{padding:40px 28px}
  .page-header{padding:56px 28px 44px}
  footer{padding:24px 28px;flex-direction:column;gap:8px;text-align:center}
  .form-row{grid-template-columns:1fr}
  .nav-links{display:none}
}
</style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a href="index.html" class="logo"><span class="br">[</span>MSH<span class="br">]</span><span class="logo-v">v4.0</span></a>
    <ul class="nav-links">
      <li><a href="index.html#tools">// tools</a></li>
      <li><a href="index.html#pricing">// pricing</a></li>
      <li><a href="index.html#contact">// contact</a></li>
    </ul>
  </div>
</nav>

<div class="page-header">
  <div class="section-tag">request.custom_dev</div>
  <h1 class="page-title">Customisation <span class="hl">Request</span></h1>
  <p class="page-sub">Tell us what you need. Whether it's a modification to an existing tool or a new command for your workflow — describe your requirement and we'll get back to you within 24 hours.</p>
</div>

<div class="form-layout">
  <div class="form-sidebar">
    <div class="sidebar-block">
      <div class="sb-title">what we customise</div>
      <p class="sb-text">Existing tools can be adapted to specific workflows, stone sizes, output formats, or naming conventions. New tools can be scoped and developed based on your requirements.</p>
    </div>
    <div class="sidebar-block">
      <div class="sb-title">process</div>
      <p class="sb-text">Submit a request → we review and respond with scope and timeline → work begins once confirmed. Most customisations are delivered within a few business days.</p>
    </div>
    <div class="sidebar-block">
      <div class="sb-title">direct contact</div>
      <div class="sb-row"><span class="sb-label">// email</span><span class="sb-val"><a href="mailto:modellingstudiohub@gmail.com">modellingstudiohub@gmail.com</a></span></div>
      <div class="sb-row"><span class="sb-label">// phone</span><span class="sb-val"><a href="tel:+919076290895">+91 90762 90895</a></span></div>
      <div class="sb-row"><span class="sb-label">// response</span><span class="sb-val">Within 24 hours</span></div>
    </div>
  </div>

  <div class="form-main">
    <h3>submit_request()</h3>
    <p class="sub">// all fields marked are required</p>
    <form action="https://formspree.io/f/mvgwravk" method="POST" enctype="multipart/form-data">
      <div class="form-row">
        <div class="form-group"><label>name *</label><input type="text" name="name" placeholder="your_name" required></div>
        <div class="form-group"><label>email *</label><input type="email" name="email" placeholder="your@email.com" required></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>phone</label><input type="tel" name="phone" placeholder="+91 00000 00000"></div>
        <div class="form-group">
          <label>related tool *</label>
          <select name="project-type" required>
            <option value="">select_tool</option>
            <option>Auto Pave Pro</option>
            <option>Azure Cutter Pro</option>
            <option>Pave Planner Pro</option>
            <option>Curves to Diamonds</option>
            <option>Single Line Pave</option>
            <option>Diamond by Crv on Srf</option>
            <option>Diamond Report By Circles</option>
            <option>Layers for Jewellers</option>
            <option>Layer BOM Report</option>
            <option>Metal Weight Calculation</option>
            <option>New Tool / Other</option>
          </select>
        </div>
      </div>
      <div class="form-group"><label>requirement *</label><textarea name="details" placeholder="// describe the workflow, expected output, and any specific constraints or preferences..." required></textarea></div>
      <div class="form-group">
        <label>reference file</label>
        <input type="file" name="attachment" accept=".pdf,.png,.jpg,.3dm,.zip">
        <p class="file-note">// accepted: pdf, png, jpg, 3dm, zip — max 10mb</p>
      </div>
      <button type="submit" class="btn-submit">Submit Request →</button>
    </form>
  </div>
</div>

<footer>
  <div class="foot-logo"><span class="br">[</span>MSH<span class="br">]</span></div>
  <div class="foot-copy">© 2025 Modelling Studio HUB. All rights reserved.</div>
</footer>
</body>
</html>
